@model List<Movie>
@{
    ViewData["Title"] = "My Movies";
}
<div class="mb-2">
    <a asp-controller="Movie" asp-action="Add">Add New Movie</a>
</div>

 <table class="table table-hover">

    <thead>
        <tr><th>Name</th><th>Year</th><th>Genre</th><th>Rating</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var movie in Model) {
            <tr>
                <td>@movie.Name</td>
                <td>@movie.Year</td>
                <td>@movie.Genre.Name</td>
                <td>@movie.Rating</td>
                <td>


                    <a asp-controller="Movie" asp-action="Edit" class="btn btn-primary"
                       asp-route-id="@movie.MovieId"
                       asp-route-slug="@movie.Slug">Edit</a>
                    <a asp-controller="Movie" asp-action="Delete" class="btn btn-primary"
                       asp-route-id="@movie.MovieId"
                       asp-route-slug="@movie.Slug">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</>